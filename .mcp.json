{
  "mcpServers": {
    "umbraco-cms": {
      "command": "npx",
      "args": ["@umbraco-cms/mcp-dev@17"]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--headless",
        "--save-video=1920x1080",
        "--viewport-size=1920x1080",
        "--save-trace",
        "--isolated",
        "--output-dir=.playwright-mcp"
      ]
    }
  }
}
