<Project>
  <PropertyGroup Condition="'$(GenerateRuntimeConfigDevFile)' == ''">
    <!--
      Razor runtime compilation resolves compilation references via DependencyContext. Package-typed
      compile references (e.g. System.Security.Cryptography.*) are not copied into the build output's
      refs/ folder, so they resolve from the NuGet global packages cache via the additional probing
      paths in *.runtimeconfig.dev.json. That file is no longer generated by default since the .NET 6
      SDK, causing "Cannot find compilation library location for package '...'" when running from build
      output. It is never emitted on publish, and published output already bundles every compile
      reference into refs/, so this only affects local development.
    -->
    <GenerateRuntimeConfigDevFile>true</GenerateRuntimeConfigDevFile>
  </PropertyGroup>
</Project>
