<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <Title>Umbraco CMS - Search - Examine provider</Title>
    <Description>An Examine (Lucene) based search provider for Umbraco Search.</Description>
    <PackageTags>umbraco search examine</PackageTags>
    <StaticWebAssetBasePath>/</StaticWebAssetBasePath>
    <!-- Disable compression for static files, because MapStaticAssets() is not used anyway (yet) -->
    <CompressionEnabled>false</CompressionEnabled>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Examine" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Umbraco.Cms.Search.Core\Umbraco.Cms.Search.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Dont include the client folder as part of packaging nuget build -->
    <Content Remove="Client\**" />

    <!-- However make these files visible to the solution -->
    <None Include="Client\public\umbraco-package.json" Pack="false" />
    <None Include="Client\package.json" Pack="false" />
    <None Include="Client\tsconfig.json" Pack="false" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="wwwroot\" />
  </ItemGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleToAttribute">
      <_Parameter1>Umbraco.Tests.Search.Examine.Integration</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

  <!-- BEGIN: Restore and build the search Examine client project (mirrors the Login block in Umbraco.Cms.StaticAssets) -->
  <PropertyGroup>
    <SearchExamineClientProjectDirectory Condition="'$(SearchExamineClientProjectDirectory)' == ''">$(ProjectDir)Client\</SearchExamineClientProjectDirectory>
    <SearchCoreClientProjectDirectory Condition="'$(SearchCoreClientProjectDirectory)' == ''">$(ProjectDir)..\Umbraco.Cms.Search.Core.Client\Client\</SearchCoreClientProjectDirectory>
    <BackofficeClientProjectDirectory Condition="'$(BackofficeClientProjectDirectory)' == ''">$(ProjectDir)..\Umbraco.Web.UI.Client\</BackofficeClientProjectDirectory>
    <SearchExamineClientAssetsPath>$(ProjectDir)wwwroot\App_Plugins\UmbracoSearchExamine</SearchExamineClientAssetsPath>
  </PropertyGroup>

  <ItemGroup>
    <Content Remove="$(SearchExamineClientAssetsPath)\**" />
  </ItemGroup>

  <Target Name="BuildSearchExamineClientStaticAssetsPreconditions" BeforeTargets="AssignTargetPaths">
    <Message Text="Skip BuildSearchExamineClient target because UmbracoBuild is '$(UmbracoBuild)' (this is not Visual Studio)" Importance="high" Condition="'$(UmbracoBuild)' != ''" />
    <Message Text="Skip BuildSearchExamineClient target because '$(SearchExamineClientAssetsPath)' already exists" Importance="high" Condition="Exists('$(SearchExamineClientAssetsPath)')" />
    <Message Text="Call BuildSearchExamineClient target because UmbracoBuild is empty (this is Visual Studio) and '$(SearchExamineClientAssetsPath)' doesn't exist" Importance="high" Condition="'$(UmbracoBuild)' == '' and !Exists('$(SearchExamineClientAssetsPath)')" />
    <CallTarget Targets="BuildSearchExamineClient" Condition="'$(UmbracoBuild)' == '' and !Exists('$(SearchExamineClientAssetsPath)')" />
  </Target>

  <Target Name="RestoreSearchExamineClient" Inputs="$(SearchExamineClientProjectDirectory)package-lock.json" Outputs="$(SearchExamineClientProjectDirectory)node_modules/.package-lock.json">
    <Message Importance="high" Text="Restoring Search Examine Client NPM packages..." />
    <Exec Command="npm i --no-fund --no-audit" WorkingDirectory="$(SearchExamineClientProjectDirectory)" />
  </Target>

  <!-- The Core Client and backoffice only need restoring (not building): this client's tsc walks their sources through tsconfig path aliases -->
  <Target Name="RestoreSearchCoreClient" Inputs="$(SearchCoreClientProjectDirectory)package-lock.json" Outputs="$(SearchCoreClientProjectDirectory)node_modules/.package-lock.json">
    <Message Importance="high" Text="Restoring Search Core Client NPM packages..." />
    <Exec Command="npm i --no-fund --no-audit" WorkingDirectory="$(SearchCoreClientProjectDirectory)" />
  </Target>

  <Target Name="RestoreBackofficeClient" Inputs="$(BackofficeClientProjectDirectory)package-lock.json" Outputs="$(BackofficeClientProjectDirectory)node_modules/.package-lock.json">
    <Message Importance="high" Text="Restoring Backoffice NPM packages..." />
    <Exec Command="npm i --no-fund --no-audit" WorkingDirectory="$(BackofficeClientProjectDirectory)" />
  </Target>

  <Target Name="BuildSearchExamineClient" DependsOnTargets="RestoreSearchExamineClient;RestoreSearchCoreClient;RestoreBackofficeClient">
    <Message Importance="high" Text="Executing Search Examine Client NPM build script..." />
    <Exec Command="npm run build" WorkingDirectory="$(SearchExamineClientProjectDirectory)" />
    <ItemGroup>
      <_SearchExamineClientAssetsBuildOutput Include="$(SearchExamineClientAssetsPath)\**" />
    </ItemGroup>
    <WriteLinesToFile File="$(IntermediateOutputPath)searchexamineclient.complete.txt" Lines="@(_SearchExamineClientAssetsBuildOutput)" Overwrite="true" />
  </Target>

  <Target Name="DefineSearchExamineClientAssets" AfterTargets="BuildSearchExamineClient" DependsOnTargets="ResolveStaticWebAssetsConfiguration">
    <ItemGroup>
      <FileWrites Include="@(_SearchExamineClientAssetsBuildOutput)" />
      <FileWrites Include="$(IntermediateOutputPath)searchexamineclient.complete.txt" />
    </ItemGroup>
    <DefineStaticWebAssets CandidateAssets="@(_SearchExamineClientAssetsBuildOutput)" SourceId="$(PackageId)" SourceType="Computed" ContentRoot="$(ProjectDir)wwwroot" BasePath="$(StaticWebAssetBasePath)">
      <Output TaskParameter="Assets" ItemName="StaticWebAsset" />
      <Output TaskParameter="Assets" ItemName="_SearchExamineClientStaticWebAssets" />
    </DefineStaticWebAssets>
    <!-- Endpoints must be defined explicitly for computed assets, otherwise the pack targets fail (NU5019) because this project has no other wwwroot assets -->
    <DefineStaticWebAssetEndpoints CandidateAssets="@(_SearchExamineClientStaticWebAssets)" ExistingEndpoints="@(StaticWebAssetEndpoint)" ContentTypeMappings="@(StaticWebAssetContentTypeMapping)">
      <Output TaskParameter="Endpoints" ItemName="StaticWebAssetEndpoint" />
    </DefineStaticWebAssetEndpoints>
  </Target>

  <Target Name="CleanSearchExamineClientStaticAssetsPreconditions" AfterTargets="Clean" Condition="'$(UmbracoBuild)' == ''">
    <Message Text="Skip CleanSearchExamineClient target because '$(SearchExamineClientAssetsPath)' doesn't exist" Importance="high" Condition="!Exists('$(SearchExamineClientAssetsPath)')" />
    <Message Text="Skip CleanSearchExamineClient target because preserve.search marker file exists" Importance="high" Condition="Exists('$(SearchExamineClientAssetsPath)') and Exists('$(SolutionDir)preserve.search')" />
    <Message Text="Call CleanSearchExamineClient target because '$(SearchExamineClientAssetsPath)' exists and preserve.search marker file doesn't exist" Importance="high" Condition="Exists('$(SearchExamineClientAssetsPath)') and !Exists('$(SolutionDir)preserve.search')" />
    <CallTarget Targets="CleanSearchExamineClient" Condition="Exists('$(SearchExamineClientAssetsPath)') and !Exists('$(SolutionDir)preserve.search')" />
  </Target>

  <Target Name="CleanSearchExamineClient">
    <ItemGroup>
      <SearchExamineClientDirectories Include="$(SearchExamineClientAssetsPath)" />
    </ItemGroup>
    <RemoveDir Directories="@(SearchExamineClientDirectories)" />
  </Target>
  <!-- END: Restore and build the search Examine client project -->

</Project>
