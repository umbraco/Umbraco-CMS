{
  "compilerOptions": {
    /* NOTE: these options must stay compatible with the in-repo backoffice sources
       (src/Umbraco.Web.UI.Client), which are part of the program via the generated
       tsconfig.json path aliases - mirror src/Umbraco.Web.UI.Login/tsconfig.json. */
    "target": "ES2024",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "incremental": true,

    /* Linting */
    "strict": true,
    "noFallthroughCasesInSwitch": true
  }
}
