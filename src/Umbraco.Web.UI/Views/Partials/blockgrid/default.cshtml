@using Umbraco.Extensions
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Umbraco.Cms.Core.Models.Blocks.BlockGridModel>
@{
    var propertyAlias = ViewData[Umbraco.Extensions.BlockGridTemplateExtensions.PropertyAliasViewDataKey] as string;
    var annotate = ((UmbracoContext?.InPreviewMode ?? false) || Umbraco.Cms.Core.Models.PublishedContent.VisualEditorPropertyTracker.IsEnabled) && !string.IsNullOrEmpty(propertyAlias);
    if (Model?.Any() != true && !annotate) { return; }
    var gridColumns = Model?.GridColumns?.ToString() ?? "12";
}
<div class="umb-block-grid" data-grid-columns="@(gridColumns)" style="--umb-block-grid--grid-columns: @(gridColumns);" data-umb-block-property="@(annotate ? propertyAlias : null)">
    @if (Model?.Any() == true)
    {
        @await Html.GetBlockGridItemsHtmlAsync(Model)
    }
</div>
