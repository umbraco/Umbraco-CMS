+				context?.currentUser,
+				(currentUser) => {
+					const allowedSections = currentUser?.allowedSections ?? [];
+					this.permitted = !allowedSections.includes(this.config.match);
+				},
+				ObserveSymbol,
+			);
+		});
+	}
