+
+		const parentUnique = this.args.unique ?? null;
+
+		return UMB_CREATE_PARTIAL_VIEW_WORKSPACE_PATH_PATTERN.generateAbsolute({
+			parentEntityType,
+			parentUnique,
+		});
+	}
+}
+
+export { UmbDefaultPartialViewCreateOptionAction as api };
